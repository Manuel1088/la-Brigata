generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Restaurant {
  id                    String               @id @default(cuid())
  name                  String
  address               String?
  phone                 String?
  companyId             String?              @map("company_id")
  stripeCustomerId      String?              @map("stripe_customer_id")
  subscriptionStatus    SubscriptionStatus   @default(FREE) @map("subscription_status")
  subscriptionPeriodEnd DateTime?            @map("subscription_period_end")
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  Employee           Employee[]
  RestaurantLocation RestaurantLocation[]
  TipEntry           TipEntry[]
  tipCardAdjustments TipCardAdjustment[]
  bookings           Booking[]
  customers          Customer[]
  ccnlRules          CCNLRules[]
  leavePolicies      LeavePolicy[]
  events             RestaurantEvent[]
  shifts             Shift[]
  shiftSwapRequests  ShiftSwapRequest[]
  tables             Table[]
  users              User[]
  company            Company?             @relation(fields: [companyId], references: [id])
  employments        Employment[]         @relation("RestaurantEmployments")
  shiftTemplates     ShiftTemplate[]
  tasks              Task[]

  @@index([companyId])
  @@map("restaurants")
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  name               String
  firstName          String?            @map("first_name")
  lastName           String?            @map("last_name")
  password           String
  role               UserRole
  hierarchyLevel     Int                @map("hierarchy_level")
  restaurantId       String?            @map("restaurant_id")
  department         String?
  isActive           Boolean            @default(true) @map("is_active")
  lastLogin          DateTime?          @map("last_login")
  createdAt          DateTime           @default(now())
  userType           UserType           @default(EMPLOYEE) @map("user_type")
  companyId          String?            @map("company_id")
  informalCompanyId  String?            @map("informal_company_id")
  teamCode           String?            @map("team_code")
  isJobSeeking       Boolean            @default(false) @map("is_job_seeking")
  phone              String?
  secondaryEmail     String?            @map("secondary_email")
  birthDate          DateTime?          @map("birth_date") @db.Date
  birthPlace         String?            @map("birth_place")
  maritalStatus      String?            @map("marital_status")
  childrenCount      Int?               @map("children_count")
  education          String?
  languages          String?
  hobbies            String?
  sports             String?
  emergencyPhone     String?            @map("emergency_phone")
  hourlyRate         Decimal?           @map("hourly_rate")
  contractType       String?            @map("contract_type")
  contractEndDate    DateTime?          @map("contract_end_date")
  startDate          DateTime?          @map("start_date")
  avatar             String?            @default("👤")
  ccnlLevel          CCNLLevel?         @map("ccnl_level")
  position           String?
  baseSalary         Decimal?           @map("base_salary")
  fiscalCode         String?            @map("fiscal_code")
  address            String?
  emergencyContact   String?            @map("emergency_contact")
  notes              String?
  weeklyHours        Int?               @map("weekly_hours")
  nightShifts        Boolean?           @default(false) @map("night_shifts")
  weekendWork        Boolean?           @default(true) @map("weekend_work")
  maxConsecutiveDays Int?               @default(6) @map("max_consecutive_days")
  contractTypeEnum   ContractType?      @map("contract_type_enum")
  stripeCustomerId           String?                  @map("stripe_customer_id")
  employeeSubscriptionStatus EmployeeSubscriptionStatus @default(FREE) @map("employee_subscription_status")
  employeeSubscriptionPeriodEnd DateTime?             @map("employee_subscription_period_end")
  auditLogs          AuditLog[]
  skills             EmployeeSkill[]
  leaveApprovals     LeaveApproval[]
  leaveBalances      LeaveBalance[]
  leaveEntitlements  LeaveEntitlement[]
  leaveRequests      LeaveRequest[]
  payrolls           Payroll[]
  payslipAnalyses    PayslipAnalysis[]
  shifts             Shift[]
  tasksAssigned      Task[]            @relation("TasksAssigned")
  tasksCreated       Task[]            @relation("TasksCreated")
  tasksCompleted     Task[]            @relation("TasksCompleted")
  swapRequestsMade   ShiftSwapRequest[] @relation("SwapRequester")
  swapRequestsTarget ShiftSwapRequest[] @relation("SwapTarget")
  userPermissions    UserPermission[]
  company            Company?           @relation("CompanyUsers", fields: [companyId], references: [id])
  informalCompany    InformalCompany?   @relation("InformalCompanyUsers", fields: [informalCompanyId], references: [id])
  restaurant         Restaurant?        @relation(fields: [restaurantId], references: [id])
  employments        Employment[]       @relation("UserEmployments")
  linkedEmployees    Employee[]         @relation("UserEmployee")
  vatRegistrationLinks      VatRegistrationUser[]
  vatAggNotificationsSent   VatAggregationNotification[] @relation("VatAggSender")
  vatAggNotificationsReceived VatAggregationNotification[] @relation("VatAggRecipient")
  notifications             Notification[]

  @@index([companyId])
  @@index([companyId, isActive])
  @@index([restaurantId])
  @@index([informalCompanyId])
  @@index([id, restaurantId]) // ✅ NUOVO - Per query dashboard rapide
  @@map("users")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  payload   Json?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

model Shift {
  id           String     @id @default(cuid())
  userId       String     @map("user_id")
  restaurantId String     @map("restaurant_id")
  date         DateTime
  startTime    DateTime   @map("start_time")
  endTime      DateTime   @map("end_time")
  department   String
  status       String     @default("scheduled")
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@index([userId, date])
  @@index([restaurantId, date])
  @@map("shifts")
}

enum ShiftSwapStatus {
  PEER_PENDING
  PENDING
  APPROVED
  REJECTED
}

enum TaskPriority {
  ALTA
  MEDIA
  BASSA
}

enum TaskStatus {
  DA_FARE
  IN_CORSO
  COMPLETATO
}

enum TaskRecurringType {
  GIORNALIERO
  SETTIMANALE
  MENSILE
}

enum ShiftTemplateType {
  PRANZO
  CENA
  SPEZZATO
  BREAKFAST
  NOTTURNO
  ALTRO
}

model ShiftTemplate {
  id           String            @id @default(cuid())
  restaurantId String            @map("restaurant_id")
  name         String
  startTime    String            @map("start_time")
  endTime      String            @map("end_time")
  type         ShiftTemplateType @default(ALTRO)
  color        String            @default("#F97316")
  isActive     Boolean           @default(true) @map("is_active")
  sortOrder    Int               @default(0) @map("sort_order")
  createdAt    DateTime          @default(now()) @map("created_at")
  restaurant   Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, isActive])
  @@map("shift_templates")
}

model Task {
  id              String             @id @default(cuid())
  restaurantId    String             @map("restaurant_id")
  assignedToId    String?            @map("assigned_to_id")
  assignedToRole  String?            @map("assigned_to_role")
  assignedById    String             @map("assigned_by_id")
  title           String
  description     String?
  dueDate         DateTime?          @map("due_date")
  priority        TaskPriority       @default(MEDIA)
  status          TaskStatus         @default(DA_FARE)
  isRecurring     Boolean            @default(false) @map("is_recurring")
  recurringType   TaskRecurringType? @map("recurring_type")
  completedAt     DateTime?          @map("completed_at")
  completedById   String?            @map("completed_by_id")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  restaurant      Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  assignedTo      User?              @relation("TasksAssigned", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedBy      User               @relation("TasksCreated", fields: [assignedById], references: [id])
  completedBy     User?              @relation("TasksCompleted", fields: [completedById], references: [id])

  @@index([restaurantId, status])
  @@index([assignedToId, status])
  @@index([dueDate])
  @@map("tasks")
}

model ShiftSwapRequest {
  id               String           @id @default(cuid())
  restaurantId     String           @map("restaurant_id")
  requesterUserId  String           @map("requester_user_id")
  targetUserId     String           @map("target_user_id")
  requesterShiftId String?          @map("requester_shift_id")
  targetShiftId    String?          @map("target_shift_id")
  requesterDate    DateTime         @map("requester_date")
  targetDate       DateTime         @map("target_date")
  status           ShiftSwapStatus  @default(PEER_PENDING)
  notes            String?
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  restaurant       Restaurant @relation(fields: [restaurantId], references: [id])
  requester        User       @relation("SwapRequester", fields: [requesterUserId], references: [id])
  target           User       @relation("SwapTarget", fields: [targetUserId], references: [id])

  @@index([restaurantId, status])
  @@index([requesterUserId])
  @@index([targetUserId])
  @@map("shift_swap_requests")
}


model Payroll {
  id            String   @id @default(cuid())
  employeeId    String   @map("employee_id")
  month         Int
  year          Int
  regularHours  Float    @default(0) @map("regular_hours")
  overtimeHours Float    @default(0) @map("overtime_hours")
  nightHours    Float    @default(0) @map("night_hours")
  holidayHours  Float    @default(0) @map("holiday_hours")
  basePay       Decimal  @map("base_pay")
  overtimePay   Decimal  @map("overtime_pay")
  nightPay      Decimal  @map("night_pay")
  holidayPay    Decimal  @map("holiday_pay")
  grossPay      Decimal  @map("gross_pay")
  inpsTax       Decimal  @map("inps_tax")
  irpefTax      Decimal  @map("irpef_tax")
  netPay        Decimal  @map("net_pay")
  createdAt     DateTime @default(now()) @map("created_at")
  employee      User     @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month, year])
  @@map("payrolls")
}

model PayslipAnalysis {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  month          Int
  year           Int
  fileName       String   @map("file_name")
  netAmount      Decimal  @map("net_amount")
  grossAmount    Decimal  @map("gross_amount")
  aiAnalysis     Json     @map("ai_analysis")
  anomalies      Json
  ccnlComparison Json     @map("ccnl_comparison")
  fiscalAnalysis Json     @map("fiscal_analysis")
  createdAt      DateTime @default(now()) @map("created_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, year, month])
  @@map("payslip_analyses")
}

model LeaveRequest {
  id              String          @id @default(cuid())
  userId          String          @map("user_id")
  startDate       DateTime        @map("start_date")
  endDate         DateTime        @map("end_date")
  type            LeaveType
  reason          String?
  status          LeaveStatus     @default(PENDING)
  approvedBy      String?         @map("approved_by")
  approvedAt      DateTime?       @map("approved_at")
  rejectedBy      String?         @map("rejected_by")
  rejectedAt      DateTime?       @map("rejected_at")
  rejectionReason String?         @map("rejection_reason")
  isUrgent        Boolean         @default(false) @map("is_urgent")
  attachment      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt @map("updated_at")
  approvals       LeaveApproval[]
  user            User            @relation(fields: [userId], references: [id])

  @@map("leave_requests")
}

model CCNLRules {
  id                   String     @id @default(cuid())
  restaurantId         String     @map("restaurant_id")
  maxDailyHours        Int        @default(8) @map("max_daily_hours")
  maxWeeklyHours       Int        @default(40) @map("max_weekly_hours")
  minRestBetweenShifts Int        @default(11) @map("min_rest_between_shifts")
  maxConsecutiveDays   Int        @default(6) @map("max_consecutive_days")
  mandatoryWeeklyRest  Int        @default(36) @map("mandatory_weekly_rest")
  restaurant           Restaurant @relation(fields: [restaurantId], references: [id])

  @@map("ccnl_rules")
}

model RestaurantEvent {
  id               String             @id @default(cuid())
  restaurantId     String             @map("restaurant_id")
  name             String
  description      String?
  date             DateTime
  expectedGuests   Int                @default(0) @map("expected_guests")
  eventType        EventType          @map("event_type")
  splitTipsByMeal  Boolean            @default(false) @map("split_tips_by_meal")
  restaurant       Restaurant         @relation(fields: [restaurantId], references: [id])
  staffNeeded      StaffRequirement[]

  @@unique([restaurantId, date, name])
  @@map("restaurant_events")
}

model StaffRequirement {
  id         String          @id @default(cuid())
  eventId    String          @map("event_id")
  department Department
  count      Int
  event      RestaurantEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("staff_requirements")
}

model LeaveApproval {
  id         String       @id @default(cuid())
  requestId  String       @map("request_id")
  approverId String       @map("approver_id")
  status     String
  comment    String?
  approvedAt DateTime?    @map("approved_at")
  createdAt  DateTime     @default(now())
  approver   User         @relation(fields: [approverId], references: [id])
  request    LeaveRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("leave_approvals")
}

model LeaveEntitlement {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  year            Int
  vacationDays    Int      @default(26) @map("vacation_days")
  rolHours        Int      @default(32) @map("rol_hours")
  paidLeaveDays   Int      @default(3) @map("paid_leave_days")
  unpaidLeaveDays Int      @default(30) @map("unpaid_leave_days")
  parentalDays    Int      @default(180) @map("parental_days")
  studyDays       Int      @default(150) @map("study_days")
  unionDays       Int      @default(8) @map("union_days")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt @map("updated_at")
  user            User     @relation(fields: [userId], references: [id])

  @@unique([userId, year])
  @@map("leave_entitlements")
}

model LeaveBalance {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  year      Int
  type      LeaveType
  total     Int
  used      Int       @default(0)
  remaining Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt @map("updated_at")
  user      User      @relation(fields: [userId], references: [id])

  @@unique([userId, year, type])
  @@map("leave_balances")
}

model LeavePolicy {
  id                 String     @id @default(cuid())
  restaurantId       String     @map("restaurant_id")
  type               LeaveType
  maxDays            Int        @map("max_days")
  noticeDays         Int        @map("notice_days")
  autoApprove        Boolean    @default(false) @map("auto_approve")
  requiresAttachment Boolean    @default(false) @map("requires_attachment")
  blackoutPeriods    String?    @map("blackout_periods")
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt @map("updated_at")
  restaurant         Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([restaurantId, type])
  @@map("leave_policies")
}

model Customer {
  id           String     @id @default(cuid())
  restaurantId String     @map("restaurant_id")
  name         String
  phone        String?
  email        String?
  notes        String?
  visitCount   Int        @default(0) @map("visit_count")
  lastVisit    DateTime?  @map("last_visit")
  createdAt    DateTime   @default(now()) @map("created_at")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  bookings     Booking[]

  @@index([restaurantId])
  @@index([restaurantId, phone])
  @@map("customers")
}

model Booking {
  id            String     @id @default(cuid())
  restaurantId  String     @map("restaurant_id")
  customerId    String?    @map("customer_id")
  tableId       String?    @map("table_id")
  area          String?
  customerName  String     @map("customer_name")
  customerPhone String?    @map("customer_phone")
  date          DateTime
  time          DateTime
  partySize     Int        @map("party_size")
  tableNumber   Int?       @map("table_number")
  status        String     @default("confirmed")
  notes         String?
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id])
  customer      Customer?  @relation(fields: [customerId], references: [id])
  table         Table?     @relation(fields: [tableId], references: [id])

  @@index([restaurantId, date])
  @@index([restaurantId, area, date])
  @@map("bookings")
}

model Table {
  id           String     @id @default(cuid())
  restaurantId String     @map("restaurant_id")
  tableNumber  Int        @map("table_number")
  seats        Int
  status       String     @default("available")
  lastUpdated  DateTime   @default(now()) @map("last_updated")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  bookings     Booking[]

  @@unique([restaurantId, tableNumber])
  @@map("tables")
}

model EmployeeSkill {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  skill     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("employee_skills")
}

model Permission {
  id              String           @id @default(cuid())
  name            String           @unique
  description     String
  category        String
  createdAt       DateTime         @default(now())
  userPermissions UserPermission[]

  @@map("permissions")
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String     @map("user_id")
  permissionId String     @map("permission_id")
  granted      Boolean    @default(true)
  grantedBy    String?    @map("granted_by")
  grantedAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  details    String?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Company {
  id               String            @id @default(cuid())
  name             String
  fiscalCode       String            @unique @map("fiscal_code")
  address          String?
  phone            String?
  email            String?
  subscriptionType String            @default("BASIC") @map("subscription_type")
  isActive         Boolean           @default(true) @map("is_active")
  createdAt        DateTime          @default(now())
  informalTeams    InformalCompany[]
  users            User[]            @relation("CompanyUsers")
  restaurants      Restaurant[]

  @@map("companies")
}

model InformalCompany {
  id              String   @id @default(cuid())
  name            String
  address         String?
  city            String?
  type            String?
  description     String?
  linkedCompanyId String?  @map("linked_company_id")
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())
  linkedCompany   Company? @relation(fields: [linkedCompanyId], references: [id])
  users           User[]   @relation("InformalCompanyUsers")

  @@map("informal_companies")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Employee {
  id                String              @id
  name              String
  email             String?             @unique
  phone             String?
  score             Int
  restDays          String[]
  ccnlLevel         CCNLLevel?
  role              EmployeeRole
  restaurantId      String
  userId            String?             @map("user_id")
  canInsertTips     Boolean             @default(false)
  canEditTips       Boolean             @default(false)
  canDeleteTips     Boolean             @default(false)
  canViewAll        Boolean             @default(false)
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  createdBy         String?
  locationId        String?             @map("location_id")
  restaurants       Restaurant          @relation(fields: [restaurantId], references: [id])
  user              User?               @relation("UserEmployee", fields: [userId], references: [id])
  location          RestaurantLocation? @relation("EmployeePrimaryLocation", fields: [locationId], references: [id])
  employeeLocations EmployeeLocation[]
  TipDistributionV2 TipDistributionV2[]
  TipEntry          TipEntry[]
  UserSession       UserSession[]

  @@index([userId])
  @@index([restaurantId, userId])
  @@index([locationId])
  @@index([name])
}

model EmployeeLocation {
  id         String             @id @default(cuid())
  employeeId String             @map("employee_id")
  locationId String             @map("location_id")
  assignedAt DateTime           @default(now()) @map("assigned_at")
  employee   Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  location   RestaurantLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([employeeId, locationId])
  @@index([employeeId])
  @@index([locationId])
  @@map("employee_locations")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model MonthlySummary {
  id            String   @id
  year          Int
  month         Int
  locationId    String
  employeeId    String
  totalAmount   Decimal
  daysWorked    Int
  averageDaily  Decimal
  cashAmount    Decimal  @default(0)
  cardAmount    Decimal  @default(0)
  foreignAmount Decimal  @default(0)
  createdAt     DateTime @default(now())

  @@unique([year, month, locationId, employeeId])
}

enum LocationType {
  RISTORANTE
  BAR
  SKYBAR
  COLAZIONI
  EVENTI
  ALTRO
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model RestaurantLocation {
  id           String       @id
  name         String
  outletName   String
  type         LocationType @default(RISTORANTE)
  capacity     Int?
  tables       Int?
  icon         String?
  isActive     Boolean      @default(true)
  sortOrder    Int          @default(0)
  openingHours Json?
  address      String?
  restaurantId String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  restaurants       Restaurant         @relation(fields: [restaurantId], references: [id])
  Employee          Employee[]         @relation("EmployeePrimaryLocation")
  employeeLocations EmployeeLocation[]
  TipEntry          TipEntry[]

  @@unique([restaurantId, name])
  @@index([restaurantId, sortOrder])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model TipDistributionV2 {
  id                 String   @id
  date               DateTime
  locationId         String
  employeeId         String
  employeeName       String
  employeeScore      Int
  totalTips          Decimal
  totalPoints        Int
  amount             Decimal
  isPresent          Boolean
  calculatedAt       DateTime @default(now())
  calculationVersion String   @default("v1.0")
  Employee           Employee @relation(fields: [employeeId], references: [id])

  @@unique([date, locationId, employeeId])
  @@index([date, locationId])
  @@index([employeeId, date])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model TipEntry {
  id                 String             @id
  date               DateTime
  location           String
  type               PaymentType
  amount             Decimal
  grossAmount        Decimal?           @map("gross_amount")
  netAmount          Decimal?           @map("net_amount")
  time               String?
  notes              String?
  restaurantId       String
  locationId         String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime
  createdBy          String
  Employee           Employee           @relation(fields: [createdBy], references: [id])
  RestaurantLocation RestaurantLocation @relation(fields: [locationId], references: [id])
  restaurants        Restaurant         @relation(fields: [restaurantId], references: [id])

  @@index([createdAt])
  @@index([date, locationId])
}

model TipCardAdjustment {
  id            String     @id @default(cuid())
  restaurantId  String     @map("restaurant_id")
  month         Int
  year          Int
  grossAmount   Decimal    @map("gross_amount")
  netAmount     Decimal    @map("net_amount")
  taxDifference Decimal    @map("tax_difference")
  appliedAt     DateTime?  @map("applied_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId, year, month])
  @@map("tip_card_adjustments")
}

