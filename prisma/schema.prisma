async function main() {
  console.log('💰 Import mance 2026 in corso...')

  const restaurant = await prisma.restaurant.findFirst({ where: { id: 'mirabelle-001' } })
  if (!restaurant) throw new Error('Ristorante non trovato — esegui prima seed-la-brigata.ts')

  const locations = await prisma.restaurantLocation.findMany({ where: { restaurantId: 'mirabelle-001' } })
  const locationMap: Record<string, string> = {}
  locations.forEach(l => locationMap[l.name] = l.id)

  const defaultEmployee = await prisma.employee.findFirst({ 
    where: { restaurantId: 'mirabelle-001', name: 'Costanzi Luca' } 
  })
  if (!defaultEmployee) throw new Error('Dipendente non trovato')

  let count = 0
  let total = 0

  for (const tip of TIPS) {
    const locationId = locationMap[tip.location] || locationMap['Mirabelle']
    const paymentType = tip.payment === 'Carta' ? 'CARD' : tip.payment === 'Contanti' ? 'CASH' : 'FOREIGN'
    const id = `tip-${tip.date}-${paymentType}-${tip.location}-${count}`

    await prisma.tipEntry.upsert({
      where: { id },
      update: {},
      create: {
        id,
        date: new Date(tip.date),
        location: tip.location,
        type: paymentType as any,
        amount: tip.amount,
        restaurantId: 'mirabelle-001',
        locationId,
        createdBy: defaultEmployee.id,
        updatedAt: new Date(),
        notes: tip.service !== 'Non Festivo' ? tip.service : undefined,
      }
    })
    count++
    total += tip.amount
  }

  console.log(`✅ ${count} mance importate`)
  console.log(`💶 Totale: €${total.toLocaleString('it-IT', {minimumFractionDigits: 2})}`)
}

main()
  .catch(console.error)
  .finally(() => prisma.$disconnect())
